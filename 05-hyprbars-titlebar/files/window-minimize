#!/usr/bin/env bash
# Minimizar/restaurar janelas no Hyprland (que nao tem minimize nativo).
#   minimize  -> manda a janela ativa pro SEU PROPRIO workspace especial
#                "special:min-<addr>" (um por janela), lembrando ws+monitor de origem.
#   restore   -> traz de volta a ultima minimizada (origem do store; se o store
#                dessincronizar, resgata qualquer janela presa pro ws ativo).
#
# POR QUE UM SPECIAL POR JANELA (corrigido 2026-06-25):
#   Um special workspace, quando QUALQUER janela dele recebe foco (focuswindow/
#   activate/alt+tab), fica VISIVEL e mostra TODO o seu conteudo no monitor focado.
#   Com todas as minimizadas num unico "special:minimized", focar uma despejava TODAS
#   no monitor em foco. Dando a cada janela o seu proprio special, um monitor so mostra
#   um special por vez: e impossivel despejar mais de uma janela de uma vez.
# IMPORTANTE: sempre movetoworkspacesilent (nunca togglespecialworkspace), pra nunca
# revelar o special. close_special_on_empty=1 destroi o special vazio ao restaurar.
# Store em /tmp/minimized-windows (linhas "<address> <ws_origem> <monitorID>", LIFO),
# reconciliado contra os clients a cada operacao (remove fantasmas).
set -uo pipefail

STORE="/tmp/minimized-windows"
# Detecta minimizadas pelo PREFIXO (cobre o esquema novo "special:min-<addr>" e o
# antigo "special:minimized", pra migrar sem quebrar janelas ja escondidas).
PREFIX="special:min"

minimized_addrs() {
  hyprctl clients -j 2>/dev/null | jq -r --arg p "$PREFIX" '.[]|select(.workspace.name|startswith($p))|.address'
}

# INVARIANTE: o store guarda SO janelas atualmente minimizadas (em algum special:min*).
# Remove entradas restauradas/fechadas. Auto-corrige, nunca acumula fantasmas.
prune_store() {
  [ -s "$STORE" ] || return 0
  local mins tmp
  mins="$(minimized_addrs)"
  tmp="$(mktemp)"
  while read -r a w m; do
    [ -n "$a" ] || continue
    if printf '%s\n' "$mins" | grep -qx "$a"; then
      printf '%s %s %s\n' "$a" "$w" "$m"
    fi
  done < "$STORE" > "$tmp"
  mv "$tmp" "$STORE"
}

case "${1:-minimize}" in
  minimize)
    info="$(hyprctl activewindow -j 2>/dev/null)"
    addr="$(printf '%s' "$info" | jq -r '.address // empty')"
    wsid="$(printf '%s' "$info" | jq -r '.workspace.id // empty')"
    wsname="$(printf '%s' "$info" | jq -r '.workspace.name // empty')"
    mon="$(printf '%s' "$info" | jq -r '.monitor // empty')"
    [ -n "$addr" ] || exit 0
    case "$wsname" in special:*) exit 0 ;; esac      # ja oculta/especial
    prune_store
    # remove entrada antiga deste address (evita duplicata no store)
    if [ -s "$STORE" ]; then
      grep -v "^$addr " "$STORE" > "$STORE.tmp" 2>/dev/null || true
      mv "$STORE.tmp" "$STORE" 2>/dev/null || true
    fi
    printf '%s %s %s\n' "$addr" "$wsid" "$mon" >> "$STORE"
    # special proprio desta janela: "special:min-<addr-sem-0x>"
    hyprctl dispatch movetoworkspacesilent "${PREFIX}-${addr#0x},address:$addr" >/dev/null 2>&1
    ;;

  restore)
    prune_store                       # reconcilia: store = so as minimizadas agora
    mins="$(minimized_addrs)"
    [ -n "$mins" ] || exit 0          # nada minimizado -> store ja esta vazio

    addr=""; ws=""
    if [ -s "$STORE" ]; then
      mapfile -t lines < "$STORE"
      for ((i=${#lines[@]}-1; i>=0; i--)); do
        a="$(awk '{print $1}' <<<"${lines[i]}")"
        if printf '%s\n' "$mins" | grep -qx "$a"; then
          addr="$a"; ws="$(awk '{print $2}' <<<"${lines[i]}")"
          unset 'lines[i]'
          printf '%s\n' "${lines[@]}" | sed '/^$/d' > "$STORE"
          break
        fi
      done
    fi
    if [ -z "$addr" ]; then     # resgate de orfa: ultima minimizada -> ws ativo atual
      addr="$(printf '%s\n' "$mins" | tail -1)"
      ws="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id')"
    fi
    [ -n "$addr" ] || exit 0
    # ws de origem invalido/oculto -> manda pro ws ativo atual
    case "$ws" in ""|-*|0) ws="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id')" ;; esac
    case "$ws" in ""|-*|0) ws=1 ;; esac
    # mover pro ws de origem ja restaura no monitor certo (o ws pertence ao monitor)
    hyprctl dispatch movetoworkspacesilent "${ws},address:$addr" >/dev/null 2>&1
    hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1
    ;;
esac
